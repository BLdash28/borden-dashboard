{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "functions": {
    "app/api/ventas/resumen/route.ts": { "maxDuration": 60 },
    "app/api/ventas/dimension/route.ts": { "maxDuration": 30 },
    "app/api/ventas/sellout/upload/route.ts": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/bots/cron",     "schedule": "0 6 * * *" },
    { "path": "/api/reportes/cron", "schedule": "0 6 * * *" },
    { "path": "/api/alertas/cron",  "schedule": "0 * * * *" }
  ]
}
