# ── Supabase ───────────────────────────────────────────────────────────────────
# Obtén estas claves en: https://supabase.com/dashboard → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# ── Supabase Database (conexión directa PostgreSQL) ────────────────────────────
# Obtén la URI en: Supabase Dashboard → Project Settings → Database → URI
# Usa el puerto 5432 (conexión directa), NO el pooler (6543) para compatibilidad con pg.Pool
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ── Resend (alertas por email) ─────────────────────────────────────────────────
# Obtén tu API key en https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Email remitente (debe ser un dominio verificado en Resend)
ALERTAS_EMAIL_FROM=alertas@tudominio.com

# Destinatarios de alertas (separados por coma)
ALERTAS_EMAIL_TO=usuario1@empresa.com,usuario2@empresa.com

# Secret para proteger el endpoint del cron (opcional pero recomendado)
CRON_SECRET=un_string_secreto_largo_aqui
